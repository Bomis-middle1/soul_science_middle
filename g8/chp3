<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Leader's Choice - Grade 8 Soul Science</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
        }

        .splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: white;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.5s ease-out;
        }

        .splash-screen.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .splash-screen img {
            max-width: 500px;
            width: 90%;
            height: auto;
            animation: logoFloat 2s ease-in-out infinite;
        }

        @keyframes logoFloat {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-20px);
            }
        }

        .container {
            max-width: 1100px;
            width: 100%;
            background: #1a1a2e;
            border-radius: 20px;
            box-shadow: 0 0 50px rgba(255, 215, 0, 0.3), 0 0 100px rgba(255, 215, 0, 0.1);
            overflow: hidden;
            opacity: 0;
            transition: opacity 0.5s ease-in;
            border: 3px solid #FFD700;
        }

        .container.visible {
            opacity: 1;
        }

        .header {
            background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
            color: #1a1a2e;
            padding: 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(255, 215, 0, 0.5);
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: repeating-linear-gradient(
                45deg,
                transparent,
                transparent 10px,
                rgba(255, 255, 255, 0.1) 10px,
                rgba(255, 255, 255, 0.1) 20px
            );
            animation: shimmer 20s linear infinite;
        }

        @keyframes shimmer {
            0% { transform: translate(0, 0); }
            100% { transform: translate(50px, 50px); }
        }

        .header h1 {
            font-size: 38px;
            margin-bottom: 10px;
            text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
            font-weight: bold;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
        }

        .stage-indicator {
            font-size: 20px;
            font-weight: bold;
            background: rgba(26, 26, 46, 0.8);
            color: #FFD700;
            padding: 12px 25px;
            border-radius: 25px;
            display: inline-block;
            margin-top: 10px;
            position: relative;
            z-index: 1;
            border: 2px solid #FFD700;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
        }

        .score-board {
            display: flex;
            justify-content: space-around;
            padding: 25px;
            background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
            border-bottom: 3px solid #FFD700;
        }

        .score-item {
            text-align: center;
            background: rgba(255, 215, 0, 0.1);
            padding: 15px 20px;
            border-radius: 10px;
            border: 2px solid rgba(255, 215, 0, 0.3);
        }

        .score-item .label {
            font-size: 14px;
            color: #FFD700;
            margin-bottom: 8px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .score-item .value {
            font-size: 32px;
            font-weight: bold;
            color: #fff;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }

        .game-container {
            padding: 30px;
            min-height: 500px;
            background: #16213e;
        }

        .scenario-box {
            background: linear-gradient(135deg, #533483 0%, #7b4397 100%);
            color: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 2px solid rgba(255, 215, 0, 0.3);
        }

        .scenario-title {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 18px;
            text-align: center;
            color: #FFD700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .scenario-text {
            font-size: 18px;
            line-height: 1.8;
            text-align: center;
            background: rgba(0,0,0,0.2);
            padding: 20px;
            border-radius: 10px;
        }

        .doors-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-top: 20px;
            perspective: 1000px;
        }

        .door {
            background: linear-gradient(135deg, #8B4513 0%, #654321 100%);
            border: 6px solid #4a2511;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.4s;
            position: relative;
            min-height: 380px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 20px 15px;
            box-shadow: 
                0 10px 30px rgba(0,0,0,0.6),
                inset 0 2px 10px rgba(255,255,255,0.1),
                inset 0 -2px 10px rgba(0,0,0,0.3);
            transform-style: preserve-3d;
        }

        .door::before {
            content: '';
            position: absolute;
            top: 8%;
            left: 8%;
            right: 8%;
            bottom: 8%;
            border: 3px solid rgba(101, 67, 33, 0.8);
            border-radius: 5px;
            pointer-events: none;
        }

        .door::after {
            content: '';
            position: absolute;
            width: 14px;
            height: 14px;
            background: radial-gradient(circle, #FFD700 0%, #B8860B 100%);
            border-radius: 50%;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            box-shadow: 
                0 2px 5px rgba(0,0,0,0.5),
                inset 0 1px 2px rgba(255,255,255,0.5);
        }

        .door:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 
                0 15px 40px rgba(255, 215, 0, 0.4),
                inset 0 2px 10px rgba(255,255,255,0.2);
            border-color: #FFD700;
        }

        .door-number {
            font-size: 42px;
            font-weight: bold;
            color: #FFD700;
            margin-bottom: 15px;
            text-shadow: 
                2px 2px 4px rgba(0,0,0,0.8),
                0 0 20px rgba(255, 215, 0, 0.5);
            z-index: 2;
        }

        .door-text {
            font-size: 15px;
            color: #fff;
            text-align: center;
            line-height: 1.6;
            padding: 18px;
            background: rgba(0,0,0,0.4);
            border-radius: 8px;
            z-index: 2;
            font-weight: 500;
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .door.correct {
            background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
            border-color: #FFD700;
            animation: correctPulse 0.8s;
            box-shadow: 
                0 0 40px rgba(46, 204, 113, 0.8),
                0 0 80px rgba(255, 215, 0, 0.6);
        }

        .door.correct::after {
            background: radial-gradient(circle, #fff 0%, #FFD700 100%);
            box-shadow: 0 0 20px rgba(255, 215, 0, 1);
        }

        .door.wrong {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
            border-color: #000;
            animation: shake 0.6s;
        }

        .door.disabled {
            pointer-events: none;
            opacity: 0.7;
        }

        @keyframes correctPulse {
            0%, 100% { transform: scale(1); }
            25% { transform: scale(1.05); }
            75% { transform: scale(1.05); }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-12px); }
            75% { transform: translateX(12px); }
        }

        .feedback {
            margin-top: 30px;
            padding: 25px;
            border-radius: 15px;
            font-size: 17px;
            line-height: 1.8;
            display: none;
            animation: slideIn 0.5s ease-out;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        .feedback.correct {
            background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
            color: #155724;
            border-left: 6px solid #28a745;
            border: 3px solid #28a745;
        }

        .feedback.wrong {
            background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
            color: #721c24;
            border-left: 6px solid #dc3545;
            border: 3px solid #dc3545;
        }

        .feedback strong {
            display: block;
            margin-bottom: 12px;
            font-size: 20px;
        }

        .next-btn {
            display: none;
            margin: 30px auto;
            padding: 18px 60px;
            border: none;
            border-radius: 35px;
            background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
            color: #1a1a2e;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 
                0 8px 20px rgba(255, 215, 0, 0.4),
                0 0 30px rgba(255, 215, 0, 0.2);
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .next-btn:hover {
            transform: translateY(-3px);
            box-shadow: 
                0 12px 30px rgba(255, 215, 0, 0.6),
                0 0 50px rgba(255, 215, 0, 0.4);
        }

        .restart-btn {
            display: none;
            margin: 30px auto;
            padding: 18px 50px;
            border: none;
            border-radius: 35px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .restart-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(102, 126, 234, 0.6);
        }

        .volume-control {
            text-align: center;
            margin-top: 25px;
            padding: 20px;
            background: rgba(255, 215, 0, 0.1);
            border-radius: 15px;
            border: 2px solid rgba(255, 215, 0, 0.3);
        }

        .volume-control label {
            color: #FFD700;
            font-weight: bold;
            font-size: 16px;
        }

        .volume-control input {
            width: 250px;
            margin-top: 10px;
        }

        .celebration {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 150px;
            animation: celebrationAnim 1.2s ease-out;
            pointer-events: none;
            z-index: 2000;
            filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.8));
        }

        @keyframes celebrationAnim {
            0% {
                transform: translate(-50%, -50%) scale(0) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translate(-50%, -50%) scale(2.5) rotate(360deg);
                opacity: 0;
            }
        }

        .final-results {
            text-align: center;
            padding: 40px;
            background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
            border-radius: 15px;
        }

        .final-results h2 {
            color: #FFD700;
            font-size: 36px;
            margin-bottom: 25px;
            text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
        }

        .rating-badge {
            font-size: 100px;
            margin: 25px 0;
            filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.6));
            animation: badgePulse 2s ease-in-out infinite;
        }

        @keyframes badgePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .rating-title {
            font-size: 32px;
            font-weight: bold;
            color: #FFD700;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
        }

        .rating-description {
            font-size: 20px;
            color: #fff;
            margin-bottom: 25px;
            line-height: 1.6;
        }

        .final-score {
            font-size: 56px;
            font-weight: bold;
            color: #FFD700;
            margin: 25px 0;
            text-shadow: 0 0 30px rgba(255, 215, 0, 0.8);
        }

        @keyframes slideIn {
            from {
                transform: translateY(-30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .spotlight {
            position: absolute;
            top: -100px;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(255, 215, 0, 0.3) 0%, transparent 70%);
            pointer-events: none;
            animation: spotlightMove 5s ease-in-out infinite;
        }

        @keyframes spotlightMove {
            0%, 100% { left: 20%; }
            50% { left: 80%; }
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 28px;
            }

            .doors-container {
                grid-template-columns: repeat(2, 1fr);
            }

            .scenario-text {
                font-size: 16px;
            }

            .door {
                min-height: 320px;
            }

            .door-text {
                font-size: 13px;
            }

            .door-number {
                font-size: 36px;
            }
        }

        @media (max-width: 480px) {
            .doors-container {
                grid-template-columns: 1fr;
            }
            
            .door {
                min-height: 280px;
            }
        }
    </style>
</head>
<body>
    <!-- Splash Screen with Logo -->
    <div class="splash-screen" id="splashScreen">
        <img src="assets/innovine-logo.png" alt="Innovine Logo" onerror="this.style.display='none'">
    </div>

    <div class="container" id="mainContainer">
        <div class="spotlight"></div>
        
        <div class="header">
            <h1>🎭 THE LEADER'S CHOICE 🎭</h1>
            <div class="stage-indicator" id="stageIndicator">Stage 1 of 10</div>
        </div>

        <div class="score-board">
            <div class="score-item">
                <div class="label">✓ Correct</div>
                <div class="value" id="correctCount">0</div>
            </div>
            <div class="score-item">
                <div class="label">📍 Stage</div>
                <div class="value" id="currentStage">1</div>
            </div>
            <div class="score-item">
                <div class="label">🏆 Score</div>
                <div class="value" id="totalScore">0/10</div>
            </div>
        </div>

        <div class="game-container" id="gameContainer">
            <div class="scenario-box">
                <div class="scenario-title" id="scenarioTitle">Choose Your Door!</div>
                <div class="scenario-text" id="scenarioText"></div>
            </div>

            <div class="doors-container" id="doorsContainer"></div>

            <div class="feedback" id="feedback"></div>

            <button class="next-btn" id="nextBtn">Next Stage →</button>
            <button class="restart-btn" id="restartBtn">🔄 Play Again</button>
        </div>

        <div class="volume-control">
            <label for="volumeSlider">🔊 Volume: <span id="volumeLabel">80%</span></label><br>
            <input type="range" id="volumeSlider" min="0" max="100" value="80">
        </div>
    </div>

    <script>
        // Hide splash screen after 5 seconds and show game
        setTimeout(() => {
            document.getElementById('splashScreen').classList.add('hidden');
            document.getElementById('mainContainer').classList.add('visible');
            initGame();
        }, 5000);

        // Audio setup
        const correctSound = new Audio('assets/correct.mp3');
        const wrongSound = new Audio('assets/wrong.mp3');
        const celebrationSound = new Audio('assets/freesound_community-claps-44774.mp3');
        
        let volume = 0.8;
        correctSound.volume = volume;
        wrongSound.volume = volume;
        celebrationSound.volume = volume;

        function playCorrectSound() {
            correctSound.currentTime = 0;
            correctSound.play().catch(e => console.log('Audio play failed:', e));
        }

        function playWrongSound() {
            wrongSound.currentTime = 0;
            wrongSound.play().catch(e => console.log('Audio play failed:', e));
        }

        function playCelebrationSound() {
            celebrationSound.currentTime = 0;
            celebrationSound.play().catch(e => console.log('Audio play failed:', e));
        }

        document.getElementById('volumeSlider').addEventListener('input', function(e) {
            volume = e.target.value / 100;
            correctSound.volume = volume;
            wrongSound.volume = volume;
            celebrationSound.volume = volume;
            document.getElementById('volumeLabel').textContent = e.target.value + '%';
        });

        // Game scenarios
        const scenarios = [
            {
                title: "Democratic vs Autocratic Leadership",
                scenario: "Your class needs to decide on a theme for the annual cultural festival. As class leader, you have a great idea, but you notice your classmates also have suggestions.",
                doors: [
                    { label: "Door A", text: "Announce your idea immediately and tell everyone to follow it" },
                    { label: "Door B", text: "Ask each classmate to share their ideas, discuss together, and vote on the best option" },
                    { label: "Door C", text: "Let classmates decide on their own without giving any input" }
                ],
                correct: 1,
                explanation: "Democratic leadership involves consulting team members before making decisions, promoting fairness and creativity."
            },
            {
                title: "Taking Responsibility",
                scenario: "Your team's science project presentation didn't go well. The teacher asks what went wrong. Your team members are blaming each other.",
                doors: [
                    { label: "Door A", text: "Blame the team member who made the mistake" },
                    { label: "Door B", text: "As team leader, take responsibility and explain what the team will improve next time" },
                    { label: "Door C", text: "Stay silent and let others handle it" }
                ],
                correct: 1,
                explanation: "Good leaders take responsibility and accountability, especially when things go wrong."
            },
            {
                title: "Effective Communication",
                scenario: "A new student joins your sports team mid-season. They don't understand the game strategy and look confused during practice.",
                doors: [
                    { label: "Door A", text: "Ignore them; they'll figure it out eventually" },
                    { label: "Door B", text: "Patiently explain the strategy, demonstrate, and encourage them to ask questions" },
                    { label: "Door C", text: "Ask someone else to deal with it" },
                    { label: "Door D", text: "Get frustrated and tell them they should already know this" }
                ],
                correct: 1,
                explanation: "Effective communicators are patient, clear, and approachable—key leadership qualities."
            },
            {
                title: "Delegation and Empowerment",
                scenario: "You're organizing a charity drive at school. There's a lot of work: making posters, collecting donations, managing social media, and coordinating volunteers.",
                doors: [
                    { label: "Door A", text: "Do everything yourself to ensure it's done correctly" },
                    { label: "Door B", text: "Assign tasks based on each team member's strengths and trust them to complete their work" },
                    { label: "Door C", text: "Ask everyone to do everything together without clear roles" }
                ],
                correct: 1,
                explanation: "Leaders delegate work efficiently and empower people by trusting their abilities."
            },
            {
                title: "Motivating Others",
                scenario: "One of your team members feels discouraged because they made several mistakes during rehearsal for the school play. They want to quit.",
                doors: [
                    { label: "Door A", text: "Tell them they're right and should probably quit" },
                    { label: "Door B", text: "Appreciate their effort, remind them that mistakes are part of learning, and encourage them to keep trying" },
                    { label: "Door C", text: "Replace them with someone else without talking to them" },
                    { label: "Door D", text: "Criticize them for making mistakes" }
                ],
                correct: 1,
                explanation: "Leaders motivate others by appreciating effort, providing encouragement, and showing empathy."
            },
            {
                title: "Servant Leadership",
                scenario: "During a group cleaning drive, everyone is working hard but getting tired. As the leader, you've been supervising from the side.",
                doors: [
                    { label: "Door A", text: "Continue supervising while others work" },
                    { label: "Door B", text: "Join your team in the work, help those who are struggling, and work alongside them" },
                    { label: "Door C", text: "Tell them to work faster and take a break yourself" }
                ],
                correct: 1,
                explanation: "Servant leaders serve their people, show empathy, and lead by example—just like General Washington in the story."
            },
            {
                title: "Vision and Goal Setting",
                scenario: "Your school's environmental club has been inactive for months. Members are unsure what to do next and lack direction.",
                doors: [
                    { label: "Door A", text: "Let the club remain inactive until someone else takes charge" },
                    { label: "Door B", text: "Create a clear vision (e.g., 'Make our school plastic-free'), set achievable goals, and inspire the team with your enthusiasm" },
                    { label: "Door C", text: "Organize one random event without a long-term plan" }
                ],
                correct: 1,
                explanation: "Visionary leaders set a clear vision, establish achievable goals, and inspire others to work toward them."
            },
            {
                title: "Handling Conflict",
                scenario: "Two members of your debate team are arguing about who should present the opening statement. The competition is tomorrow, and tension is high.",
                doors: [
                    { label: "Door A", text: "Pick your favorite person without explanation" },
                    { label: "Door B", text: "Let them argue it out while you stay out of it" },
                    { label: "Door C", text: "Listen to both sides, acknowledge their strengths, and make a fair decision based on their skills" },
                    { label: "Door D", text: "Cancel the debate participation" }
                ],
                correct: 2,
                explanation: "Leaders are proactive, make fair decisions, and resolve conflicts by listening and evaluating objectively."
            },
            {
                title: "Honesty and Integrity",
                scenario: "Your team won a competition, but you realized later that one member accidentally broke a rule during the contest. No one else noticed.",
                doors: [
                    { label: "Door A", text: "Keep quiet and enjoy the victory" },
                    { label: "Door B", text: "Inform the organizers about the mistake, even if it means losing the prize" },
                    { label: "Door C", text: "Blame the mistake on someone else" }
                ],
                correct: 1,
                explanation: "Honesty and truthfulness are essential leadership qualities. Leaders live with integrity."
            },
            {
                title: "Continuous Improvement",
                scenario: "After leading your group project, you receive feedback that your leadership could improve in time management. What do you do?",
                doors: [
                    { label: "Door A", text: "Ignore the feedback; you think you did fine" },
                    { label: "Door B", text: "Get defensive and argue that the feedback is wrong" },
                    { label: "Door C", text: "Thank them for the feedback, reflect on it, and work on improving your time management skills" },
                    { label: "Door D", text: "Blame your team for the time management issues" }
                ],
                correct: 2,
                explanation: "Great leaders are committed to continuous improvement and welcome constructive feedback."
            }
        ];

        let currentScenarioIndex = 0;
        let correctAnswers = 0;

        function initGame() {
            currentScenarioIndex = 0;
            correctAnswers = 0;
            updateScoreboard();
            loadScenario();
        }

        function loadScenario() {
            if (currentScenarioIndex >= scenarios.length) {
                showFinalResults();
                return;
            }

            const scenario = scenarios[currentScenarioIndex];
            
            document.getElementById('scenarioTitle').textContent = scenario.title;
            document.getElementById('scenarioText').textContent = scenario.scenario;
            document.getElementById('stageIndicator').textContent = `Stage ${currentScenarioIndex + 1} of ${scenarios.length}`;
            
            const doorsContainer = document.getElementById('doorsContainer');
            doorsContainer.innerHTML = '';
            
            scenario.doors.forEach((door, index) => {
                const doorElement = document.createElement('div');
                doorElement.className = 'door';
                doorElement.innerHTML = `
                    <div class="door-number">${door.label}</div>
                    <div class="door-text">${door.text}</div>
                `;
                doorElement.onclick = () => selectDoor(index);
                doorsContainer.appendChild(doorElement);
            });

            document.getElementById('feedback').style.display = 'none';
            document.getElementById('nextBtn').style.display = 'none';
        }

        function selectDoor(selectedIndex) {
            const scenario = scenarios[currentScenarioIndex];
            const doors = document.querySelectorAll('.door');
            const feedback = document.getElementById('feedback');

            doors.forEach(door => door.classList.add('disabled'));

            if (selectedIndex === scenario.correct) {
                doors[selectedIndex].classList.add('correct');
                feedback.className = 'feedback correct';
                feedback.innerHTML = `<strong>✅ Excellent Choice!</strong>${scenario.explanation}`;
                correctAnswers++;
                playCorrectSound();
                showCelebration('🌟');
            } else {
                doors[selectedIndex].classList.add('wrong');
                doors[scenario.correct].classList.add('correct');
                feedback.className = 'feedback wrong';
                feedback.innerHTML = `<strong>❌ Not Quite Right</strong>The correct choice was <strong>${scenario.doors[scenario.correct].label}</strong>. ${scenario.explanation}`;
                playWrongSound();
            }

            feedback.style.display = 'block';
            updateScoreboard();

            setTimeout(() => {
                document.getElementById('nextBtn').style.display = 'block';
            }, 1500);
        }

        function showCelebration(emoji) {
            const celebration = document.createElement('div');
            celebration.className = 'celebration';
            celebration.textContent = emoji;
            document.body.appendChild(celebration);
            setTimeout(() => celebration.remove(), 1200);
        }

        function updateScoreboard() {
            document.getElementById('correctCount').textContent = correctAnswers;
            document.getElementById('currentStage').textContent = currentScenarioIndex + 1;
            document.getElementById('totalScore').textContent = `${correctAnswers}/${scenarios.length}`;
        }

        function showFinalResults() {
            const percentage = Math.round((correctAnswers / scenarios.length) * 100);
            let rating, badge, description;

            if (correctAnswers >= 9) {
                rating = "Visionary Leader";
                badge = "🌟";
                description = "Outstanding! You demonstrate exceptional leadership qualities!";
                playCelebrationSound();
            } else if (correctAnswers >= 7) {
                rating = "Confident Leader";
                badge = "💼";
                description = "Great job! You have strong leadership skills with room to grow!";
            } else if (correctAnswers >= 5) {
                rating = "Emerging Leader";
                badge = "🌱";
                description = "Good work! You're developing solid leadership habits!";
            } else if (correctAnswers >= 3) {
                rating = "Learning Leader";
                badge = "📚";
                description = "Keep practicing! Leadership is a journey!";
            } else {
                rating = "Aspiring Leader";
                badge = "🔰";
                description = "Review the chapter and try again. You can do it!";
            }

            const gameContainer = document.getElementById('gameContainer');
            gameContainer.innerHTML = `
                <div class="final-results">
                    <h2>🎭 GAMESHOW COMPLETE! 🎭</h2>
                    <div class="rating-badge">${badge}</div>
                    <div class="rating-title">${rating}</div>
                    <div class="final-score">${correctAnswers}/${scenarios.length}</div>
                    <div class="rating-description">${description}</div>
                    <p style="margin-top: 25px; font-size: 20px; color: #FFD700;">
                        You scored <strong>${percentage}%</strong> on your leadership journey!
                    </p>
                </div>
            `;

            document.getElementById('restartBtn').style.display = 'block';
        }

        document.getElementById('nextBtn').addEventListener('click', () => {
            currentScenarioIndex++;
            loadScenario();
        });

        document.getElementById('restartBtn').addEventListener('click', () => {
            document.getElementById('restartBtn').style.display = 'none';
            initGame();
        });
    </script>
</body>
</html>
